{
  "defaults": {
    "projectKey": "PLAT",
    "assigneeAccountId": "712020:example-default-account-id",
    "priorityName": "Medium",
    "labels": ["ai-generated", "auto-created"]
  },
  "rules": [
    {
      "name": "observability-bugs",
      "match": {
        "systems": ["grafana", "loki", "tempo", "otel"],
        "issueTypes": ["Bug", "Improvement"]
