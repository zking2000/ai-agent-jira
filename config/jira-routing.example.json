        "labels": ["observability"],
        "components": ["grafana"],
        "customFields": {
          "customfield_12345": "SRE"
        }
      }
    },
    {
      "name": "delivery-platform",
      "match": {
        "keywords": ["jenkins", "pipeline", "audit", "gateway", "kong"]
      },
      "apply": {
        "projectKey": "DEVOPS",
        "assigneeAccountId": "712020:delivery-owner-account-id",
